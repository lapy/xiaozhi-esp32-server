# Production image: application code on top of the published server-base image.
# CI should pass SERVER_BASE_IMAGE=ghcr.io/${{ github.repository }}:server-base.
# Local default pulls the lapy org base (build server-base first if missing).
ARG SERVER_BASE_IMAGE=ghcr.io/lapy/xiaozhi-esp32-server:server-base
FROM ${SERVER_BASE_IMAGE}

COPY main/xiaozhi-server .

CMD ["python", "app.py"]
